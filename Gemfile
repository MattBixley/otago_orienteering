source "https://rubygems.org"

# GitHub Pages compatible build. Using the github-pages gem keeps the local
# build in sync with what GitHub Pages runs.
gem "github-pages", group: :jekyll_plugins
gem "jekyll-feed"
gem "jekyll-seo-tag"
gem "jekyll-sitemap"

# Windows / WSL friendliness
gem "webrick", "~> 1.8"
